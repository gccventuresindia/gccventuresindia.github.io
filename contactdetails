      --light: #f4f4f4;
      --white: #ffffff;
      --text: #333333;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; color: var(--text); background: var(--white); }
    nav { background: var(--primary); padding: 16px 40px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; }
    nav .logo { color: var(--gold); font-size: 20px; font-weight: 700; }
    nav ul { list-style: none; display: flex; gap: 28px; }
    nav ul li a { color: var(--white); text-decoration: none; font-size: 15px; transition: color 0.3s; }
    nav ul li a:hover { color: var(--gold); }
    .nav-cta { background: var(--accent); padding: 8px 20px; border-radius: 5px; color: var(--white) !important; font-weight: 600; }
    .page-hero { background: linear-gradient(135deg, var(--primary), #16213e); color: var(--white); text-align: center; padding: 60px 40px; }
    .page-hero h1 { font-size: 38px; margin-bottom: 12px; }
    .page-hero h1 span { color: var(--gold); }
    .page-hero p { font-size: 17px; opacity: 0.88; max-width: 580px; margin: 0 auto; }
    .contact-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; max-width: 1000px; margin: 60px auto; padding: 0 40px; }
    .form-box { background: var(--light); border-radius: 12px; padding: 36px 32px; border-top: 5px solid var(--accent); }
    .form-box h2 { font-size: 22px; color: var(--primary); margin-bottom: 22px; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 14px; font-weight: 600; color: var(--primary); margin-bottom: 6px; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 12px 14px; border: 1.5px solid #ddd; border-radius: 6px; font-size: 15px; font-family: 'Segoe UI', sans-serif; transition: border 0.3s; background: var(--white); }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: var(--accent); }
    .form-group textarea { height: 120px; resize: vertical; }
    .submit-btn { width: 100%; background: var(--accent); color: var(--white); padding: 14px; border: none; border-radius: 6px; font-size: 16px; font-weight: 700; cursor: pointer; transition: background 0.3s; }
    .submit-btn:hover { background: var(--gold); color: var(--primary); }
    .info-box { display: flex; flex-direction: column; gap: 18px; }
    .info-box h2 { font-size: 22px; color: var(--primary); margin-bottom: 4px; }
    .info-box p { font-size: 15px; line-height: 1.8; color: #555; }
    .contact-card { background: var(--light); border-radius: 10px; padding: 20px 22px; display: flex; align-items: center; gap: 16px; border-left: 5px solid var(--gold); text-decoration: none; color: var(--text); transition: transform 0.3s, box-shadow 0.3s; }
    .contact-card:hover { transform: translateX(6px); box-shadow: 0 6px 20px rgba(0,0,0,0.09); }
    .contact-card .ci { font-size: 30px; }
    .contact-card .cd h4 { font-size: 15px; color: var(--primary); font-weight: 700; }
    .contact-card .cd p { font-size: 14px; color: #666; margin-top: 2px; }
    .divider { font-size: 13px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 1px; padding: 4px 0; }
    .whatsapp-banner { background: #25D366; border-radius: 12px; padding: 24px; text-align: center; color: var(--white); }
    .whatsapp-banner h3 { font-size: 18px; margin-bottom: 8px; }
    .whatsapp-banner p { font-size: 14px; opacity: 0.9; margin-bottom: 16px; }
    .whatsapp-banner .wa-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .wa-btn { background: var(--white); color: #25D366; padding: 10px 22px; border-radius: 6px; font-weight: 700; text-decoration: none; font-size: 14px; }
    .wa-btn:hover { background: var(--primary); color: var(--white); }
    .availability { background: #f0fff4; border: 1.5px solid #b2f5c8; border-radius: 10px; padding: 16px 18px; font-size: 14px; line-height: 1.9; }
    .dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: #22c55e; margin-right: 6px; animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
    .faq-wrap { max-width: 800px; margin: 0 auto; }
    .faq-item { border-bottom: 1px solid #eee; padding: 20px 0; }
    .faq-item h4 { font-size: 16px; color: var(--primary); margin-bottom: 8px; }
    .faq-item p { font-size: 14px; line-height: 1.8; color: #555; }
    footer { background: var(--primary); color: #aaa; text-align: center; padding: 28px; font-size: 14px; margin-top: 60px; }
    footer a { color: var(--gold); text-decoration: none; }
    @media (max-width: 768px) {
      .contact-wrap { grid-template-columns: 1fr; padding: 0 20px; margin: 40px auto; }
      .page-hero h1 { font-size: 26px; }
      nav ul { display: none; }
      .whatsapp-banner .wa-btns { flex-direction: column; align-items: center; }
    }
  </style>
</head>
